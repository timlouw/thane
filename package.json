{
  "name": "thane",
  "version": "0.1.0",
  "description": "Lightweight compile-time optimized component framework",
  "author": "Tim Louw",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "components",
    "framework",
    "signals",
    "reactive",
    "compiler",
    "typescript",
    "frontend",
    "light-dom"
  ],
  "homepage": "https://github.com/timlouw/thane#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timlouw/thane.git"
  },
  "bugs": {
    "url": "https://github.com/timlouw/thane/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "main": "dist/runtime/index.js",
  "types": "dist/runtime/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/compiler",
    "dist/contracts",
    "dist/runtime",
    "client.d.ts"
  ],
  "bin": {
    "thane": "./dist/compiler/cli/thane.js"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./runtime": {
      "types": "./dist/runtime/internal.d.ts",
      "import": "./dist/runtime/internal.js",
      "default": "./dist/runtime/internal.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "default": "./dist/compiler/index.js"
    },
    "./router": {
      "types": "./dist/runtime/router.d.ts",
      "import": "./dist/runtime/router.js",
      "default": "./dist/runtime/router.js"
    },
    "./compiler/cli": {
      "types": "./dist/compiler/cli/index.d.ts",
      "import": "./dist/compiler/cli/index.js",
      "default": "./dist/compiler/cli/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test ./src",
    "e2e:test": "playwright test -c ./e2e/playwright.config.ts",
    "e2e:test:headed": "playwright test -c ./e2e/playwright.config.ts --headed --workers=1",
    "e2e:ui": "playwright test -c ./e2e/playwright.config.ts --ui --headed --workers=1",
    "e2e:ui:trace": "playwright test -c ./e2e/playwright.config.ts --ui --headed --trace on --workers=1",
    "format": "prettier --write \"**/*.{ts,json,html}\"",
    "format:check": "prettier --check \"**/*.{ts,json,html}\"",
    "types:e2e": "cd e2e && bun ../src/compiler/cli/thane.ts types",
    "types:benchmark": "cd benchmark && bun ../src/compiler/cli/thane.ts types",
    "types:example": "cd example-apps/thane-app && bun ../../src/compiler/cli/thane.ts types",
    "typecheck:e2e": "cd e2e && bun ../src/compiler/cli/thane.ts typecheck",
    "typecheck:benchmark": "cd benchmark && bun ../src/compiler/cli/thane.ts typecheck",
    "typecheck:example": "cd example-apps/thane-app && bun ../../src/compiler/cli/thane.ts typecheck",
    "test:apps": "bun run typecheck:e2e && bun run typecheck:benchmark && bun run typecheck:example",
    "test:benchmark": "npm pack && cd benchmark && bun install && bun run build",
    "verify": "bun run format:check && bun run build && bun run test:apps && bun run test:benchmark && bun run test && bun run e2e:test"
  },
  "dependencies": {
    "esbuild": "^0.27.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.2.1",
    "prettier": "^3.8.1"
  }
}
