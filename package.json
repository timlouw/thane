{
  "name": "thane",
  "version": "0.0.65",
  "description": "Lightweight compile-time optimized component framework",
  "author": "Tim Louw",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "components",
    "framework",
    "signals",
    "reactive",
    "compiler",
    "typescript",
    "frontend",
    "light-dom"
  ],
  "homepage": "https://github.com/timlouw/thane#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/timlouw/thane.git"
  },
  "bugs": {
    "url": "https://github.com/timlouw/thane/issues"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "main": "dist/runtime/index.js",
  "types": "dist/runtime/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/compiler",
    "dist/runtime",
    "client.d.ts"
  ],
  "bin": {
    "thane": "./dist/compiler/cli/thane.js"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js",
      "default": "./dist/runtime/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js",
      "default": "./dist/compiler/index.js"
    },
    "./compiler/cli": {
      "types": "./dist/compiler/cli/index.d.ts",
      "import": "./dist/compiler/cli/index.js",
      "default": "./dist/compiler/cli/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test ./src",
    "e2e:build": "bun run build && bun ./dist/compiler/cli/thane.js build --entry ./e2e/contract-app/main.ts --out ./dist/e2e --html ./e2e/contract-app/index.html --assets ./e2e/contract-app/assets",
    "e2e:serve": "bun ./e2e/server.ts",
    "e2e:test": "playwright test -c ./e2e/playwright.config.ts",
    "e2e:test:headed": "playwright test -c ./e2e/playwright.config.ts --headed --workers=1",
    "e2e:ui": "playwright test -c ./e2e/playwright.config.ts --ui --headed --workers=1",
    "e2e:ui:trace": "playwright test -c ./e2e/playwright.config.ts --ui --headed --trace on --workers=1",
    "format": "prettier --write \"**/*.{ts,json,html}\"",
    "format:check": "prettier --check \"**/*.{ts,json,html}\""
  },
  "dependencies": {
    "esbuild": "^0.27.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.5",
    "prettier": "^3.8.1"
  }
}
