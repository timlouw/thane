{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "thane": ["../../src/runtime/index.ts"],
      "thane/router": ["../../src/runtime/router.ts"]
    },
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true
  },
  "include": [
    "./src/**/*.ts",
    "./.thane/types/**/*.d.ts"
  ]
}
