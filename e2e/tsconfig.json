{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": [
    "contract-app/**/*.ts",
    "memory-leak-demo/**/*.ts",
    "router-app/**/*.ts",
    ".thane/types/client.d.ts",
    ".thane/types/router/**/*.d.ts"
  ],
  "exclude": ["node_modules", "tests"]
}
