{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": ["contract-app/**/*.ts", "memory-leak-demo/**/*.ts", "router-app/**/*.ts"],
  "exclude": ["node_modules", "tests"]
}
