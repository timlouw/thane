{
  "name": "thane-website",
  "version": "1.0.0",
  "description": "Official Thane framework website — built with Thane",
  "author": "Tim Louw",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "thane dev --entry ./main.ts --out ./dist --html ./index.html",
